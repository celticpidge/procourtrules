{
  "buildCommand": "chmod +x node_modules/.bin/* && vite build",
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/feedback.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
